# YiYi Control - 环境配置示例
# 复制为 .env 并按实际情况填写，docker compose 会自动加载同目录的 .env 文件
#
# cp .env.example .env

# ============================================================
# 必填：服务器公网 IP 或域名
# 所有服务都用这一个值向注册中心注册自己的访问地址
# 单机部署填服务器 IP，域名部署填域名（不带协议前缀）
# ============================================================
YIYI_SERVER_HOST=your.server.ip.or.domain

# ============================================================
# 数据库配置
# ============================================================
YIYI_DB_USER=chris
YIYI_DB_PASSWORD=change_me_in_production

# ============================================================
# 服务间鉴权 token（所有服务共享同一个值，建议修改为随机字符串）
# ============================================================
YIYI_SERVICE_TOKEN=change_me_to_a_random_secret

# ============================================================
# 第三方登录（可选）
# ============================================================
# Telegram Bot（OTP 验证码 + Login Widget 一键登录）
# bot-token 从 @BotFather 获取；bot-username 是 bot 的 @用户名（不带 @）
YIYI_TELEGRAM_BOT_TOKEN=
YIYI_TELEGRAM_BOT_USERNAME=

# Google 一键登录（OAuth Client ID，从 Google Cloud Console 获取）
YIYI_GOOGLE_CLIENT_ID=
